<Window x:Class="RadioPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radio Player"
        Height="250"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F4F4F4">

    <Grid Margin="20">

        <Border Background="White"
                CornerRadius="10"
                Padding="15"
                BorderBrush="#D0D0D0"
                BorderThickness="1">

            <StackPanel>

                <!-- Заголовок -->
                <TextBlock Text="Internet Radio"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Поле ввода -->
                <TextBox x:Name="UrlBox"
                         Height="35"
                         FontSize="14"
                         Padding="8,3"
                         Margin="0,0,0,25"
                         BorderBrush="#AAAAAA"
                         Text="https://radiorecord.hostingradio.ru/dream96.aacp"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button x:Name="StartButton"
                            Content="Start"
                            Width="120"
                            Height="40"
                            Margin="10"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Click="StartButton_Click"/>

                    <Button x:Name="StopButton"
                            Content="Stop"
                            Width="120"
                            Height="40"
                            Margin="10"
                            Background="#E53935"
                            Foreground="White"
                            BorderThickness="0"
                            Click="StopButton_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>
</Window>
