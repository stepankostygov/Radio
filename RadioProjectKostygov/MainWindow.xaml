<Window x:Class="RadioPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radio Player"
        Height="250"
        Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <!-- Заголовок -->
            <TextBlock Text="Internet Radio"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Поле ввода -->
            <TextBox x:Name="UrlBox"
                     Height="35"
                     FontSize="14"
                     Margin="0,0,0,25"
                     Text="https://radiorecord.hostingradio.ru/dream96.aacp"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button x:Name="StartButton"
                        Content="Start"
                        Width="120"
                        Height="40"
                        Margin="10"
                        Click="StartButton_Click"/>

                <Button x:Name="StopButton"
                        Content="Stop"
                        Width="120"
                        Height="40"
                        Margin="10"
                        Click="StopButton_Click"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</Window>