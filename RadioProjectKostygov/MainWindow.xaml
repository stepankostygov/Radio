<Window x:Class="RadioPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radio Player"
        Height="280"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F"
        ResizeMode="NoResize">

    <Border CornerRadius="15"
            Margin="10"
            Background="#2A2A40"
            Padding="20">

        <Grid>

            <StackPanel>

                <!-- Заголовок -->
                <TextBlock Text="🎵 Internet Radio"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <!-- Подпись -->
                <TextBlock Text="Stream URL"
                           Foreground="#CFCFE8"
                           FontSize="13"
                           Margin="5,0,0,5"/>

                <!-- Поле ввода -->
                <TextBox x:Name="UrlBox"
                         Height="38"
                         FontSize="14"
                         Padding="10,5"
                         Background="#3A3A55"
                         Foreground="White"
                         BorderBrush="#5A5A80"
                         BorderThickness="1"
                         Margin="0,0,0,30"
                         Text="https://radiorecord.hostingradio.ru/dream96.aacp"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button x:Name="StartButton"
                            Content="▶ Start"
                            Width="130"
                            Height="42"
                            Margin="10"
                            FontWeight="SemiBold"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Click="StartButton_Click"/>

                    <Button x:Name="StopButton"
                            Content="■ Stop"
                            Width="130"
                            Height="42"
                            Margin="10"
                            FontWeight="SemiBold"
                            Background="#E53935"
                            Foreground="White"
                            BorderThickness="0"
                            Click="StopButton_Click"/>

                </StackPanel>

            </StackPanel>

        </Grid>

    </Border>

</Window><Window x:Class="RadioPlayer.MainWindow"
